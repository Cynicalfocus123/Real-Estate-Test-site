generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ListingType {
  BUY
  RENT
  SENIOR_HOME
}

enum SaleCategory {
  NORMAL
  DISTRESS
  FORECLOSURE
  PRE_FORECLOSURE
  FIXER_UPPER
  URGENT_SALE
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SavedListingsEmailFrequency {
  REALTIME
  DAILY
  NONE
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  displayName       String?
  phone             String?
  address           String?
  role              UserRole @default(USER)
  emailVerified     Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  favorites         Favorite[]
  notificationPrefs AccountNotificationPreference?
}

model Property {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  listingType   ListingType
  saleCategory  SaleCategory   @default(NORMAL)
  propertyType  String
  status        PropertyStatus @default(DRAFT)
  price         Int?
  rentPrice     Int?
  depositAmount Int?
  depositText   String?
  bedrooms      Int
  bathrooms     Int
  sqm           Float
  landSize      Float?
  builtYear     Int?
  province      String
  city          String
  district      String?
  subdistrict   String?
  streetAddress String?
  postalCode    String?
  country       String         @default("Thailand")
  latitude      Float?
  longitude     Float?
  description   String
  features      String[]       @default([])
  amenities     String[]       @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  images        PropertyImage[]
  faqs          PropertyFAQ[]
  favorites     Favorite[]

  @@index([listingType, status, province, city])
  @@index([price])
  @@index([rentPrice])
}

model PropertyImage {
  id           String   @id @default(cuid())
  propertyId   String
  url          String
  thumbnailUrl String
  cardUrl      String
  galleryUrl   String
  heroUrl      String
  altText      String?
  width        Int
  height       Int
  sortOrder    Int      @default(0)
  isCover      Boolean  @default(false)
  createdAt    DateTime @default(now())

  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, sortOrder])
}

model PropertyFAQ {
  id         String   @id @default(cuid())
  propertyId String
  question   String
  answer     String
  sortOrder  Int      @default(0)

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, sortOrder])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([propertyId])
}

model AccountNotificationPreference {
  userId                       String                     @id
  savedListingsEmailFrequency  SavedListingsEmailFrequency @default(REALTIME)
  marketingUpdates             Boolean                    @default(true)

  user                         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
}
